    "motion": "^12.23.24",
    "next": "16.0.3",
    "next-themes": "^0.4.6",
    "openai": "^6.18.0",
    "pg": "^8.16.3",
    "quill": "^2.0.3",
    "quill-delta-to-html": "^0.12.1",
    "quill-mention": "^6.1.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-email": "^5.0.5",
    "react-force-graph-2d": "^1.29.0",
    "react-hook-form": "^7.66.1",
    "react-quill-new": "^3.6.0",
