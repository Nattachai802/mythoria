{
  "name": "mythoria",
  "version": "0.5.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:full",
    "dev:windows": "npm run dev:full:windows",
    "dev:lite": "NODE_OPTIONS='--max-old-space-size=1024' next dev --webpack",
    "dev:lite:windows": "cross-env NODE_OPTIONS=--max-old-space-size=1024 next dev --webpack",
    "dev:full": "NODE_OPTIONS='--max-old-space-size=3072' next dev --webpack",
    "dev:full:windows": "cross-env NODE_OPTIONS=--max-old-space-size=3072 next dev --webpack",
    "dev:python:linux": "cd pythonservice && venv/bin/python -m uvicorn main:app --reload --port 8000",
    "dev:python:windows": "cd pythonservice && venv\\Scripts\\python -m uvicorn main:app --reload --port 8000",
    "dev:all:lite:linux": "concurrently --restart-tries -1 \"npm run dev:lite\" \"npm run dev:python:linux\"",
    "dev:all:lite:windows": "concurrently --restart-tries -1 \"npm run dev:lite:windows\" \"npm run dev:python:windows\"",
    "dev:all:linux": "concurrently --restart-tries -1 \"npm run dev:full\" \"npm run dev:python:linux\"",
    "dev:all:windows": "concurrently --restart-tries -1 \"npm run dev:full:windows\" \"npm run dev:python:windows\"",
    "db:start": "pg_ctl start",
    "db:stop": "pg_ctl stop",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.33.0",
    "@hookform/resolvers": "^5.2.2",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.1",
    "@react-email/render": "^2.0.0",
    "@types/dagre": "^0.7.53",
    "@types/diff-match-patch": "^1.0.36",
    "@xyflow/react": "^12.10.0",
    "better-auth": "^1.3.34",
    "class-variance-authority": "^0.7.1",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "diff-match-patch": "^1.0.5",
